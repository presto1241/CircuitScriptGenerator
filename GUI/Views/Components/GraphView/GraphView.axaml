             x:Class="CircuitScriptGenerator.GUI.Views.Components.GraphView"
             x:DataType="vm:GraphViewViewModel"
             Background="Transparent">
    
  <UserControl.DataContext>
    <vm:GraphViewViewModel/>
  </UserControl.DataContext>

